{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/schemas/judge-output-grsh-v1.json",
  "title": "Judge Output - GRSh",
  "type": "object",
  "required": [
    "candidate_id",
    "decision",
    "issue_class_id",
    "issue_class",
    "subtype",
    "entity_key",
    "grounding_ok",
    "likely_ocr_artifact",
    "expert_rules_applied",
    "rationale_short"
  ],
  "properties": {
    "candidate_id": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": [
        "confirmed",
        "rejected",
        "uncertain",
        "suppress_by_rule",
        "out_of_scope",
        "defer_to_adjacent"
      ]
    },
    "issue_class_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 11
    },
    "issue_class": {
      "type": "string",
      "enum": [
        "completeness",
        "identity_addressing",
        "cross_view_consistency",
        "requirement_compatibility",
        "functional_topology",
        "parameter_adequacy",
        "engineering_calculation",
        "interdisciplinary_coordination",
        "versioning_references",
        "constructability",
        "documentation_quality"
      ]
    },
    "subtype": { "type": "string" },
    "entity_key": { "type": "string" },
    "field": { "type": ["string", "null"] },
    "grounding_ok": { "type": "boolean" },
    "final_severity": {
      "type": ["string", "null"],
      "enum": ["CRITICAL", "EXPLOITATION", "RECOMMENDED", "CHECK_ADJACENT", "NONE", null]
    },
    "materiality": {
      "type": "string",
      "enum": ["material", "no_material_load", "unknown"]
    },
    "likely_ocr_artifact": { "type": "boolean" },
    "expert_rules_applied": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "phase_balance_small_load_exception",
          "normative_ref_cap",
          "exact_line_id_only",
          "ocr_artifact_guard",
          "adjacent_section_required",
          "scope_exclusion"
        ]
      }
    },
    "supporting_evidence_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contradicting_evidence_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rationale_short": { "type": "string" },
    "normalized_finding": { "type": ["string", "null"] },
    "needs_human_review": { "type": "boolean" }
  }
}
