{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/schemas/candidate-bundle-grsh-v1.json",
  "title": "Candidate Bundle - Judge Stage - GRSh",
  "type": "object",
  "required": [
    "candidate_id",
    "issue_class_id",
    "issue_class",
    "subtype",
    "entity_key",
    "matching_policy",
    "candidate_claim",
    "evidence",
    "flags"
  ],
  "properties": {
    "candidate_id": { "type": "string" },
    "issue_class_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 11
    },
    "issue_class": {
      "type": "string",
      "enum": [
        "completeness",
        "identity_addressing",
        "cross_view_consistency",
        "requirement_compatibility",
        "functional_topology",
        "parameter_adequacy",
        "engineering_calculation",
        "interdisciplinary_coordination",
        "versioning_references",
        "constructability",
        "documentation_quality"
      ]
    },
    "subtype": { "type": "string" },
    "entity_key": { "type": "string" },
    "secondary_entity_key": { "type": ["string", "null"] },
    "field": { "type": ["string", "null"] },
    "matching_policy": {
      "type": "string",
      "enum": [
        "exact_line_id_only",
        "exact_panel_id_only",
        "exact_breaker_id_only",
        "exact_room_no_only",
        "pairwise_swap_check",
        "rule_applicability_check"
      ]
    },
    "generator": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "candidate_claim": {
      "type": "object",
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "non_unique_identifier",
            "attribute_mismatch",
            "designation_description_swap",
            "requirement_conflict",
            "missing_required_attribute",
            "calculation_trigger",
            "other"
          ]
        },
        "summary": { "type": "string" },
        "proposed_severity": {
          "type": "string",
          "enum": ["CRITICAL", "EXPLOITATION", "RECOMMENDED", "CHECK_ADJACENT"]
        }
      }
    },
    "values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "value_raw", "value_norm"],
        "properties": {
          "label": { "type": "string" },
          "value_raw": {},
          "value_norm": {},
          "unit": { "type": ["string", "null"] },
          "mention_id": { "type": ["string", "null"] }
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["page", "sheet", "view_type"],
        "properties": {
          "mention_id": { "type": ["string", "null"] },
          "page": { "type": "integer" },
          "sheet": { "type": ["string", "null"] },
          "block_id": { "type": ["string", "null"] },
          "view_type": {
            "type": "string",
            "enum": [
              "single_line_scheme",
              "cable_layout_node",
              "specification",
              "general_notes",
              "load_table",
              "plan",
              "other"
            ]
          },
          "crop_ref": { "type": ["string", "null"] },
          "page_image_ref": { "type": ["string", "null"] },
          "raw_excerpt": { "type": ["string", "null"] },
          "normalized_excerpt": { "type": ["string", "null"] }
        }
      }
    },
    "rule_hints": {
      "type": "object",
      "properties": {
        "phase_balance_nonfinding_threshold_kw": { "type": ["number", "null"] },
        "require_single_phase_dominant_load": { "type": ["boolean", "null"] },
        "normative_refs_max_severity": { "type": ["string", "null"] },
        "materiality_default": { "type": ["string", "null"] }
      }
    },
    "flags": {
      "type": "object",
      "required": [
        "likely_ocr_artifact",
        "needs_adjacent_sections",
        "out_of_scope"
      ],
      "properties": {
        "likely_ocr_artifact": { "type": "boolean" },
        "needs_adjacent_sections": { "type": "boolean" },
        "out_of_scope": { "type": "boolean" }
      }
    },
    "source_mention_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_judge_question": { "type": ["string", "null"] }
  }
}
