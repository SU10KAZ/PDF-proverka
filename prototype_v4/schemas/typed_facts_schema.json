{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/schemas/typed-facts-grsh-v1.json",
  "title": "Typed Facts Layer - GRSh",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "discipline",
    "scope",
    "entity_mentions",
    "relation_mentions",
    "uncertainty_events"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "document_id": { "type": "string" },
    "discipline": { "const": "GRSh" },
    "scope": {
      "type": "object",
      "required": ["included", "excluded"],
      "properties": {
        "included": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["GRSh"]
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["EG", "UZDP", "ApartmentPanels", "LightningProtection"]
        }
      }
    },
    "entity_mentions": {
      "type": "array",
      "items": { "$ref": "#/$defs/entityMention" }
    },
    "relation_mentions": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationMention" }
    },
    "uncertainty_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertaintyEvent" }
    }
  },
  "$defs": {
    "bbox": {
      "type": "object",
      "required": ["x1", "y1", "x2", "y2"],
      "properties": {
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" }
      }
    },
    "evidenceRef": {
      "type": "object",
      "required": ["page", "sheet", "view_type"],
      "properties": {
        "page": { "type": "integer" },
        "sheet": { "type": ["string", "null"] },
        "block_id": { "type": ["string", "null"] },
        "view_type": {
          "type": "string",
          "enum": [
            "single_line_scheme",
            "cable_layout_node",
            "specification",
            "general_notes",
            "load_table",
            "plan",
            "other"
          ]
        },
        "crop_ref": { "type": ["string", "null"] },
        "page_image_ref": { "type": ["string", "null"] },
        "bbox": { "$ref": "#/$defs/bbox" }
      }
    },
    "attribute": {
      "type": "object",
      "required": [
        "name",
        "value_type",
        "value_raw",
        "value_norm",
        "parse_confidence"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "designation",
            "description",
            "position",
            "source_panel",
            "destination_panel",
            "phase_count",
            "phase_section_mm2",
            "neutral_count",
            "neutral_section_mm2",
            "pe_count",
            "pe_section_mm2",
            "cable_mark",
            "breaker_model",
            "breaker_nominal_a",
            "trip_unit_type",
            "trip_delay_capable",
            "ct_ratio_primary_a",
            "ct_ratio_secondary_a",
            "ct_accuracy_class",
            "power_kw",
            "apparent_power_kva",
            "demand_factor",
            "voltage_drop_pct",
            "ikz_1a",
            "length_m",
            "room_no",
            "note_text",
            "requirement_type",
            "norm_ref_code",
            "formula_text",
            "address",
            "reserve_breaker_count",
            "reserve_space_pct",
            "other"
          ]
        },
        "value_type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "array", "object", "null"]
        },
        "value_raw": {},
        "value_norm": {},
        "unit": { "type": ["string", "null"] },
        "value_source": {
          "type": "string",
          "enum": ["ocr", "vision", "table_parse", "text_parse", "inferred"]
        },
        "parse_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ambiguous_values": {
          "type": "array",
          "items": {}
        },
        "likely_ocr_artifact": { "type": "boolean", "default": false }
      }
    },
    "entityMention": {
      "type": "object",
      "required": [
        "mention_id",
        "entity_type",
        "normalized_label",
        "source_context",
        "attributes",
        "confidence"
      ],
      "properties": {
        "mention_id": { "type": "string" },
        "entity_type": {
          "type": "string",
          "enum": [
            "panel",
            "line",
            "breaker",
            "cable",
            "current_transformer",
            "note",
            "spec_row",
            "load",
            "room",
            "tray",
            "fire_box",
            "busduct",
            "formula",
            "norm_ref",
            "other"
          ]
        },
        "canonical_key_hint": { "type": ["string", "null"] },
        "raw_label": { "type": ["string", "null"] },
        "normalized_label": { "type": "string" },
        "exact_keys": {
          "type": "object",
          "properties": {
            "line_id": { "type": ["string", "null"] },
            "panel_id": { "type": ["string", "null"] },
            "breaker_id": { "type": ["string", "null"] },
            "ct_id": { "type": ["string", "null"] },
            "room_no": { "type": ["string", "null"] },
            "spec_position": { "type": ["string", "null"] }
          }
        },
        "source_context": { "$ref": "#/$defs/evidenceRef" },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/attribute" }
        },
        "raw_text_excerpt": { "type": ["string", "null"] },
        "flags": {
          "type": "object",
          "properties": {
            "likely_ocr_artifact": { "type": "boolean", "default": false },
            "needs_adjacent_sections": { "type": "boolean", "default": false },
            "out_of_scope_ref": { "type": "boolean", "default": false }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "relationMention": {
      "type": "object",
      "required": [
        "relation_id",
        "relation_type",
        "from_mention_id",
        "to_mention_id",
        "confidence",
        "evidence_refs"
      ],
      "properties": {
        "relation_id": { "type": "string" },
        "relation_type": {
          "type": "string",
          "enum": [
            "feeds",
            "protects",
            "described_in",
            "references",
            "applies_to",
            "located_in",
            "mirrors",
            "duplicate_identifier_with",
            "same_entity_candidate",
            "other"
          ]
        },
        "from_mention_id": { "type": "string" },
        "to_mention_id": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "uncertaintyEvent": {
      "type": "object",
      "required": [
        "uncertainty_id",
        "kind",
        "reason",
        "severity"
      ],
      "properties": {
        "uncertainty_id": { "type": "string" },
        "mention_id": { "type": ["string", "null"] },
        "kind": {
          "type": "string",
          "enum": [
            "ocr_artifact",
            "ambiguous_reading",
            "missing_attribute",
            "cross_page_link_uncertain",
            "out_of_scope",
            "needs_adjacent_section",
            "low_resolution"
          ]
        },
        "reason": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    }
  }
}
