  },

  "norms": {
    "class2": {
      "default_norm": "ГОСТ 21.601-2011, п. 4 — обозначения трубопроводов и арматуры должны быть уникальными и соответствовать спецификации",
      "default_risk": "Путаница при монтаже, неоднозначность привязки арматуры к системе"
    },
    "class3": {
      "diameter_fields": {
        "norm": "СП 30.13330.2020, п. 5 — диаметры трубопроводов определяются расчётом",
        "risk": "Несоответствие диаметра расчётному → недостаточный напор, шум, износ"
      },
      "pressure_fields": {
        "norm": "СП 30.13330.2020, п. 5.2 — рабочее давление в системе водоснабжения",
        "risk": "Несоответствие давления → риск разрушения трубопровода или недостаточный напор"
      },
      "slope_fields": {
        "norm": "СП 30.13330.2020, п. 8.3 — уклоны самотёчных канализационных трубопроводов",
        "risk": "Недостаточный уклон → засоры, заиливание, нарушение самотёчного режима"
      },
      "topology_fields": {
        "norm": null,
        "risk": "Ошибка в привязке арматуры к системе → проблемы при монтаже"
      },
      "default": {
        "norm": null,
        "risk": "Несоответствие между чертежами → ошибки при монтаже"
      }
    },
    "class4": {
      "slope": {
        "norm": "СП 30.13330.2020, п. 8.3.1 — минимальные уклоны: Ø50 — 0.03, Ø100 — 0.02, Ø150 — 0.01",
        "risk": "Уклон ниже нормативного → засоры канализации, нарушение самотёчного режима"
      },
      "fire_water": {
        "norm": "СП 10.13130.2020 — внутренний противопожарный водопровод",
        "risk": "Несоответствие системы ВПВ нормативным требованиям → угроза безопасности при пожаре"
      },
      "default": {
