    "dn_mm": "условный проход",
    "pn_mpa": "условное давление",
    "flowrate_lps": "расход",
    "power_kw": "мощность",
    "pump_type": "тип насоса",
    "has_backup": "наличие резерва",
    "hydrant_type": "тип гидранта",
    "nozzle_type": "тип насадка",
    "designation": "обозначение",
    "description": "описание"
  },

  "field_units": {
    "diameter_mm": "мм",
    "pressure_mpa": "МПа",
    "length_m": "м",
    "dn_mm": "мм",
    "pn_mpa": "МПа",
