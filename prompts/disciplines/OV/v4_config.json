      "room": ["room_no"]
    },
    "priority_tasks": [
      {
        "id": 1,
        "title": "Парсинг маркировки систем П/В/ПД",
        "critical": true,
        "description": "Везде где видишь маркировку систем вентиляции (П1, П2, В1, В2, ПД1, ВД1 и т.д.) — извлеки system_id и тип системы (приточная/вытяжная/дымоудаление/подпор).",
        "examples": [
          {"input": "П1 L=5000 м³/ч", "output": "system_id=П1, airflow_m3h=5000, тип=приточная"},
          {"input": "ВД1 (дымоудаление)", "output": "system_id=ВД1, тип=дымоудаление"},
          {"input": "ПД2 подпор в ЛК", "output": "system_id=ПД2, тип=подпор воздуха"}
        ]
      },
      {
        "id": 2,
        "title": "Расходы воздуха и сечения воздуховодов",
        "critical": true,
        "description": "Для каждого участка воздуховода — извлеки airflow_m3h, размеры сечения (diameter или width×height), скорость. Сверь расход на схеме и на плане.",
        "key_phrases": ["м³/ч", "L=", "расход воздуха", "сечение", "Ø"]
      },
      {
        "id": 3,
        "title": "Огнезадерживающие клапаны",
        "critical": true,
        "description": "Все КОЗ/ОЗК — извлечь fire_resistance_ei, размер, привязку к системе и к противопожарной преграде. Проверить наличие в местах пересечения противопожарных преград.",
        "key_phrases": ["КОЗ", "ОЗК", "огнезадерживающий", "EI 60", "EI 90", "EI 120"]
      },
      {
        "id": 4,
        "title": "Примечания с требованиями",
        "critical": true,
        "description": "Примечания на чертежах — прочитай дословно.",
        "key_phrases": [
          "огнестойкость воздуховодов",
          "компенсация при дымоудалении",
          "подпор воздуха в ЛК",
          "не менее",
          "EI 150",
          "EI 60"
        ]
      },
      {
        "id": 5,
        "title": "Параметры оборудования",
        "critical": false,
        "description": "Каждая единица оборудования (вентустановка, вентилятор, калорифер) — извлечь designation, airflow_m3h, pressure_pa, power_kw, thermal_power_kw."
      }
    ]
  },

