    "loop_id": "номер шлейфа",
    "capacity": "ёмкость",
    "input_count": "количество входов",
    "output_count": "количество выходов",
    "outlet_type": "тип розетки",
    "port_count": "количество портов",
    "rack_units": "количество юнитов",
    "note_text": "текст примечания",
    "identifier_uniqueness": "уникальность маркера"
  },

  "field_units": {
    "length_m": "м",
    "mounting_height_m": "м",
    "capacity": "шт.",
    "input_count": "шт.",
