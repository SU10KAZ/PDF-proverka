  "generators": {
    "class2_identity": {
      "eligible_types": ["element", "weld", "bolt_connection"],
      "unique_per_sheet_types": ["element"]
    },
    "class3_cross_view": {
      "watch_fields": {
        "element": [
          "steel_grade", "thickness_mm", "section_type",
          "profile_name", "weight_kg", "fire_resistance_class"
        ],
        "weld": ["weld_type", "length_mm", "leg_mm", "weld_category"],
        "bolt_connection": ["bolt_class", "bolt_diameter_mm", "bolt_count", "connection_type"],
        "spec_row": ["designation", "steel_grade", "weight_kg"]
      },
      "safety_critical_fields": [
        "steel_grade", "thickness_mm",
        "leg_mm", "weld_category",
        "bolt_class", "bolt_diameter_mm", "bolt_count"
      ],
      "topology_fields": ["element_group"]
    },
    "class4_requirement_conflict": {
      "note_requirement_patterns": [
        {
          "pattern_id": "fire_protection_required",
          "regex": "(?:огнезащит|предел\\s*огнестойкости|R\\d{2,3})",
          "applies_to": "all_elements",
          "required_field": "fire_resistance_class",
          "required_value": "specified"
        },
        {
          "pattern_id": "anticorrosion_required",
          "regex": "(?:антикоррози|грунт|покрытие|покраска)",
          "applies_to": "all_elements",
          "required_field": "anticorrosion_system",
          "required_value": "specified"
        }
      ]
    }
  },

