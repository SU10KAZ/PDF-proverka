{
  "schema_version": "1.0",
  "discipline": "KM",
  "discipline_label": "Конструкции металлические",

  "extraction": {
    "scope_label": "Металлические конструкции каркаса, связи, площадки, лестницы",
    "scope_included": ["Frame", "Beams", "Columns", "Trusses", "Bracing", "Platforms", "Stairs"],
    "scope_excluded": ["Reinforcement", "ConcreteElements", "Foundations"],
    "entity_types": ["element", "weld", "bolt_connection", "section", "profile", "spec_row", "note", "other"],
    "exact_key_fields": {
      "element": "element_mark",
      "weld": "weld_id",
      "bolt_connection": "connection_id",
      "section": "section_id",
      "profile": "profile_id",
      "spec_row": "spec_position"
    },
    "attribute_enum": {
      "element": [
        "steel_grade", "thickness_mm", "section_type",
        "profile_name", "length_mm", "weight_kg",
        "fire_resistance_class", "element_group"
      ],
      "weld": [
        "weld_type", "length_mm", "leg_mm",
        "electrode_mark", "welding_method",
        "joint_type", "weld_category"
      ],
      "bolt_connection": [
        "bolt_class", "bolt_diameter_mm", "bolt_count",
        "connection_type", "washer_type",
        "torque_nm", "surface_treatment"
      ],
      "section": [
        "profile_name", "dimensions", "steel_grade",
        "moment_of_inertia", "section_modulus"
      ],
      "profile": [
        "profile_type", "designation",
        "height_mm", "width_mm", "thickness_mm"
      ],
      "note": ["note_text", "requirement_type"],
      "spec_row": ["designation", "description", "steel_grade", "weight_kg", "quantity"],
      "other": []
    },
    "priority_tasks": [
      {
        "id": 1,
        "title": "Марки стали",
        "critical": true,
        "description": "Для каждого элемента определить марку стали (С245, С255, С345, 09Г2С и др.), сверить соответствие условиям эксплуатации, температуре, ответственности конструкции. Категория стали по ударной вязкости по ГОСТ 27772-2015.",
        "examples": [
          {"input": "Б1 — двутавр 30Б1, сталь С255", "output": "element_mark=Б1, profile_name=30Б1, steel_grade=С255"},
          {"input": "К1 — труба 219×8, 09Г2С-12", "output": "element_mark=К1, profile_name=219x8, steel_grade=09Г2С-12"}
        ]
      },
      {
        "id": 2,
        "title": "Сварные швы",
        "critical": true,
        "description": "Для каждого сварного соединения — тип (стыковое, угловое, тавровое, нахлёсточное), катет углового шва, длина, марка электрода, способ сварки, категория шва по ответственности.",
        "key_phrases": [
          "катет шва", "стыковой шов", "угловой шов", "тавровое",
          "электрод", "полуавтоматическая", "разделка кромок"
        ]
      },
      {
        "id": 3,
        "title": "Болтовые соединения",
        "critical": true,
        "description": "Класс прочности болтов (4.6, 5.6, 8.8, 10.9), диаметр, количество в узле, шаг и расстояние до края. Фрикционные соединения: обработка поверхностей, усилие натяжения.",
        "key_phrases": [
          "высокопрочный болт", "класс прочности", "фрикционное",
          "сдвигоустойчивое", "усилие натяжения", "шайба"
        ]
      },
      {
        "id": 4,
        "title": "Огнезащита металлоконструкций",
        "critical": true,
        "description": "Требуемый предел огнестойкости (R15–R120), тип огнезащиты (конструктивная/тонкослойная), приведённая толщина металла. Сертификаты на огнезащитные составы.",
        "key_phrases": [
          "огнезащита", "предел огнестойкости", "вспучивающаяся краска",
          "приведённая толщина", "R30", "R45", "R60", "R90"
        ]
      },
      {
        "id": 5,
        "title": "Примечания с требованиями",
        "critical": false,
        "description": "Примечания на чертежах и в общих указаниях — прочитай дословно. Особое внимание к требованиям по сварке, антикоррозийной защите, допускам.",
        "key_phrases": [
          "антикоррозийная защита", "грунтовка", "покраска",
          "допуск", "ГОСТ 23118", "монтажный стык"
        ]
      }
    ]
  },

  "canonical_memory": {
