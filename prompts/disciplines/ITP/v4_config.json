    "priority_tasks": [
      {
        "id": 1,
        "title": "Теплообменники — мощность и параметры",
        "critical": true,
        "description": "Для каждого теплообменника извлечь мощность, расходы, температурные графики первичного и вторичного контуров. Проверить запас мощности (10-15% отопление, до 25% ГВС)."
      },
      {
        "id": 2,
        "title": "Насосы — расход и напор",
        "critical": true,
        "description": "Для каждого насоса извлечь расход, напор, электрическую мощность. Проверить 100% резервирование циркуляционных насосов отопления. Наличие обратных клапанов на обвязке."
      },
      {
        "id": 3,
        "title": "Трубопроводы — диаметры и материалы",
        "critical": true,
        "description": "Для каждого трубопровода извлечь диаметр, материал, толщину изоляции. Проверить соответствие скоростей (до 3 м/с), уклоны (не менее 0.002)."
      },
      {
        "id": 4,
        "title": "Приборы учёта — УУТЭ",
        "critical": true,
        "description": "Извлечь характеристики теплосчётчика, расходомеров, термопреобразователей, датчиков давления. Проверить прямые участки до/после расходомеров, соответствие Постановлению №1034."
      },
      {
        "id": 5,
        "title": "Регулирующие клапаны и автоматика",
        "critical": false,
        "description": "Для каждого клапана извлечь Kvs, DN, тип привода. Проверить авторитет клапана (не менее 0.5). Проверить наличие контроллера погодозависимого регулирования."
      }
    ]
  },

