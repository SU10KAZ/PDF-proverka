    "priority_tasks": [
      {
        "id": 1,
        "title": "Технологическое оборудование",
        "critical": true,
        "description": "Для каждой единицы оборудования — обозначение, модель, мощность, габариты, подключения (вода, канализация, электричество, вентиляция). Сверка с разделами ЭОМ, ВК, ОВиК.",
        "examples": [
          {"input": "Поз. 1 — Пароконвектомат RATIONAL iCombi Pro 20-1/1, 37 кВт", "output": "designation=Поз. 1, description=Пароконвектомат, model=RATIONAL iCombi Pro 20-1/1, power_kw=37"},
          {"input": "Поз. 5 — Холодильный шкаф Polair CM114-S, 0.35 кВт", "output": "designation=Поз. 5, description=Холодильный шкаф, model=Polair CM114-S, power_kw=0.35"}
        ]
      },
      {
        "id": 2,
        "title": "Проходы между оборудованием",
        "critical": true,
        "description": "Ширина проходов: рабочие >= 0.7 м, основные >= 1.2 м, эвакуационные >= 1.0 м. Проходы для МГН >= 0.9 м. Зазоры до стен.",
        "key_phrases": [
          "проход", "зазор", "расстояние между", "ширина прохода",
          "доступ для обслуживания", "эвакуационный проход"
        ]
      },
      {
        "id": 3,
        "title": "Зонирование помещений",
        "critical": true,
        "description": "Функциональное зонирование: чистые/грязные зоны, потоки сырья и готовой продукции, разделение посетителей и персонала. Загрузочные зоны.",
        "key_phrases": [
          "чистая зона", "грязная зона", "загрузочная",
          "поток сырья", "поток готовой продукции",
          "вход персонала", "вход посетителей"
        ]
      },
      {
        "id": 4,
        "title": "Примечания с требованиями",
        "critical": false,
        "description": "Примечания на чертежах — прочитай дословно. Требования к отделке, температурному режиму, вентиляции, санитарным нормам.",
        "key_phrases": [
          "жироуловитель", "трап напольный", "влагостойкая отделка",
          "бактерицидный", "температурный режим", "класс чистоты"
        ]
      }
    ]
