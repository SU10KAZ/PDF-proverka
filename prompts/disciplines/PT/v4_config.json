    "class4_requirement_conflict": {
      "note_requirement_patterns": [
        {
          "pattern_id": "backup_pump_required",
          "regex": "(?:резервн|100\\s*%\\s*резерв).*нас",
          "applies_to": "fire_pumps",
          "required_field": "backup_pump",
          "required_value": true
        },
        {
          "pattern_id": "ring_network_required",
          "regex": "(?:кольцев|кольцевая\\s*сеть)",
          "applies_to": "pipe_network",
          "required_field": "network_type",
          "required_value": "ring"
        },
        {
          "pattern_id": "power_category_1",
          "regex": "(?:I\\s*категори|первой\\s*категори).*(?:электро|питан|надёжн)",
          "applies_to": "fire_pump_power",
          "required_field": "power_reliability_category",
          "required_value": "I"
        }
      ]
    }
  },

