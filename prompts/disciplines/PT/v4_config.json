      "pump_pt": "pump_id",
      "valve_pt": "valve_id",
      "nozzle": "nozzle_id",
      "sprinkler": "sprinkler_id",
      "room": "room_no",
      "spec_row": "spec_position"
    },
    "attribute_enum": {
