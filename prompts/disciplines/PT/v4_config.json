      "spec_row": ["designation", "description", "diameter_mm", "quantity", "material"],
      "room": ["room_no", "area_m2", "fire_hazard_class"],
      "other": []
    },
    "priority_tasks": [
      {
        "id": 1,
        "title": "Диаметры трубопроводов",
        "critical": true,
        "description": "Для каждого участка трубопровода — диаметр, материал, тип системы (ВПВ / спринклерная / дренчерная). Сверка диаметров между аксонометрией, планами и спецификацией. Скорость воды: не более 3 м/с для стояков, 5 м/с для магистралей.",
        "examples": [
          {"input": "Ст. ВГП Ду50 ГОСТ 3262", "output": "diameter_mm=50, material=Ст. ВГП, pipe_type=ВПВ"},
          {"input": "Труба стальная Ду100 ГОСТ 10704", "output": "diameter_mm=100, material=Ст. электросварная, pipe_type=магистраль"}
        ]
      },
      {
        "id": 2,
        "title": "Пожарные гидранты и краны",
        "critical": true,
        "description": "Для каждого ПК — DN (50 или 65), длина рукава (15 или 20 м), диаметр ствола, высота установки (1.35 м ±0.15 м). Каждая точка помещения — не менее 2 струй от разных ПК.",
        "key_phrases": [
          "пожарный кран", "ПК", "ШПК", "рукав",
          "ствол", "DN50", "DN65", "радиус действия"
        ]
      },
      {
        "id": 3,
        "title": "Насосы пожаротушения",
        "critical": true,
        "description": "Основной и резервный насос (100% резерв), жокей-насос. Подача (м³/ч или л/с), напор (м или МПа), мощность. Автоматика пуска: от ОПС, от падения давления, дистанционно. Электроснабжение I категории.",
        "key_phrases": [
          "насос пожаротушения", "основной насос", "резервный насос",
          "жокей-насос", "автоматический пуск", "I категория"
        ]
      },
      {
        "id": 4,
        "title": "Спринклерные оросители",
        "critical": true,
        "description": "Тип оросителя, температура срабатывания (57/68/79°C), ориентация (вверх/вниз/универсальный), K-фактор, площадь покрытия. Расстановка по СП 485 (расстояние между оросителями и до стен).",
        "key_phrases": [
          "ороситель", "спринклер", "температура срабатывания",
          "розетка вверх", "розетка вниз", "интенсивность орошения"
        ]
      },
      {
        "id": 5,
        "title": "Примечания с требованиями",
        "critical": false,
        "description": "Примечания на чертежах — прочитай дословно. Требования к испытаниям, уклонам, запорной арматуре, дренажу.",
        "key_phrases": [
          "гидравлическое испытание", "уклон", "дренаж",
          "обратный клапан", "задвижка", "манометр"
        ]
      }
    ]
  },

