{
  "schema_version": "1.0",
  "discipline": "PT",
  "discipline_label": "Противопожарный водопровод",

  "extraction": {
    "scope_label": "ВПВ, АУПТ (спринклерная/дренчерная), насосная станция, пожарные краны",
    "scope_included": ["VPV", "AUPT_Sprinkler", "AUPT_Drench", "PumpStation", "FireHydrant", "Reservoir"],
    "scope_excluded": ["DomesticWater", "Sewage", "Heating"],
    "entity_types": ["pipe_pt", "hydrant", "pump_pt", "valve_pt", "nozzle", "sprinkler", "spec_row", "note", "room", "other"],
    "exact_key_fields": {
      "pipe_pt": "pipe_id",
